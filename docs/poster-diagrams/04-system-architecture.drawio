        <!-- Bottom note -->
        <mxCell id="bottomNote" value="&lt;font color=&quot;#666&quot; style=&quot;font-size:12px;&quot;&gt;All three flows use Supabase RLS for security. Calendar sync uses CRDTs (Yjs) for conflict-free collaborative editing across multiple users.&lt;/font&gt;" style="fontFamily=Calibri;text;html=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="100" y="480" width="750" height="20" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
