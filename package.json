{
  "name": "travyl",
  "version": "0.0.1",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "nohoist": [
      "**/eslint-config-next",
      "**/eslint-config-next/**",
      "**/next",
      "**/next/**",
      "**/tailwindcss",
      "**/tailwindcss/**"
    ]
  },
  "scripts": {
    "mobile": "npm run start -w @travyl/mobile",
    "web": "npm run dev -w @travyl/web",
    "lint": "npm run lint -ws",
    "typecheck": "npm run typecheck -ws"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.434",
    "@remotion/player": "^4.0.434",
    "framer-motion": "^12.35.1",
    "remotion": "^4.0.434"
  }
}
