{
  "name": "travyl",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "npm -w @travyl/mobile run start",
    "web": "npm -w @travyl/web run dev",
    "web:fresh": "npm -w @travyl/web run dev:fresh",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "postinstall": "patch-package"
  },
  "overrides": {
    "react-dom": "19.2.6"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/aws-lambda": "^8.10.161",
    "aws-cdk-lib": "^2.243.0",
    "constructs": "^10.5.1",
    "patch-package": "^8.0.1",
    "sst": "^4.13.1",
    "tsx": "^4.21.0"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1014.0",
    "@aws-sdk/client-dynamodb": "^3.1011.0",
    "@aws-sdk/client-eventbridge": "^3.1011.0",
    "@aws-sdk/client-location": "^3.1011.0",
    "@aws-sdk/client-s3": "^3.1044.0",
    "@aws-sdk/client-sesv2": "^3.1014.0",
    "@aws-sdk/lib-dynamodb": "^3.1011.0",
    "@aws-sdk/s3-request-presigner": "^3.1044.0"
  }
}
